<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.remindme" path="/org/gnome/shell/extensions/remindme/">
    <!-- Prayer Settings -->
    <key name="prayer-enabled" type="b">
      <default>true</default>
      <summary>Enable prayer reminders</summary>
    </key>
    <key name="prayer-method" type="s">
      <default>'MWL'</default>
      <summary>Calculation method for prayer times</summary>
    </key>
    <key name="prayer-template" type="s">
      <default>'5-prayers'</default>
      <summary>Prayer template preset (5-prayers, 3-prayers, custom)</summary>
    </key>
    <key name="prayer-lat" type="d">
      <default>0.0</default>
      <summary>Latitude for prayer times</summary>
    </key>
    <key name="prayer-lon" type="d">
      <default>0.0</default>
      <summary>Longitude for prayer times</summary>
    </key>

    <!-- Water Settings -->
    <key name="water-enabled" type="b">
      <default>true</default>
      <summary>Enable water reminders</summary>
    </key>
    <key name="water-interval" type="i">
      <default>60</default>
      <summary>Interval between water reminders (minutes)</summary>
    </key>
    <key name="water-start" type="i">
      <default>8</default>
      <summary>Start hour for water reminders</summary>
    </key>
    <key name="water-end" type="i">
      <default>22</default>
      <summary>End hour for water reminders</summary>
    </key>

    <!-- Break Settings -->
    <key name="break-enabled" type="b">
      <default>true</default>
      <summary>Enable break reminders</summary>
    </key>
    <key name="break-interval" type="i">
      <default>25</default>
      <summary>Interval between break reminders (minutes)</summary>
    </key>
    <key name="break-duration" type="i">
      <default>5</default>
      <summary>Duration of the break (minutes)</summary>
    </key>
    <key name="custom-reminders" type="s">
      <default>'[]'</default>
      <summary>JSON-encoded custom reminders list</summary>
    </key>

    <!-- General Settings -->
    <key name="notification-sound" type="b">
      <default>true</default>
      <summary>Play sound for notifications</summary>
    </key>
    <key name="last-update" type="x">
      <default>0</default>
      <summary>Timestamp of last update</summary>
    </key>
  </schema>
</schemalist>
